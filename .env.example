# Copy to `.env` and fill in. run.sh auto-loads this file.

# OpenAI — enables LLM final-verdict synthesis. If unset, the app falls back to
# deterministic heuristic synthesis (still fully functional).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.1

# Database (matches docker-compose: host port 5433 -> container 5432)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/stock_agent

# Backend / CORS
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional Yahoo provider reliability tuning
# MARKET_DATA_TIMEOUT_SECONDS=20
# MARKET_DATA_MAX_ATTEMPTS=3
# FUNDAMENTALS_TIMEOUT_SECONDS=15
# FUNDAMENTALS_MAX_ATTEMPTS=2
# NEWS_TIMEOUT_SECONDS=15
# NEWS_MAX_ATTEMPTS=2
# NEWS_MAX_HEADLINES=8
